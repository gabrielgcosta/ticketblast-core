# Database Configuration
POSTGRES_USER=ticketblast_user
POSTGRES_PASSWORD=ticketblast_password
POSTGRES_DB=ticketblast_db

# RabbitMQ Configuration
RABBITMQ_DEFAULT_USER=guest
RABBITMQ_DEFAULT_PASS=guest
