# ##############################################################################
# TicketBlast Core - Environment Variables Template
# Copy this file to '.env' and adjust the values for your local environment.
# ##############################################################################

# Application Configuration
APP_ENV=development

# Database Connection Details
DB_HOST=localhost
DB_PORT=5432
POSTGRES_USER=ticketblast_user
POSTGRES_PASSWORD=ticketblast_password
POSTGRES_DB=ticketblast_db

# Alternative Database URL (takes precedence if set)
# DATABASE_URL=postgres://ticketblast_user:ticketblast_password@localhost:5432/ticketblast_db?sslmode=disable

# Authentication Secrets
JWT_SECRET=your_jwt_secret_key_here

# Redis Configuration
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0

# RabbitMQ Configuration
RABBITMQ_DEFAULT_USER=guest
RABBITMQ_DEFAULT_PASS=guest
